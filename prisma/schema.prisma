datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Booking {
  id                String   @id @default(cuid())
  name              String
  phone             String
  email             String?
  enquiryType       String
  sessionPreference String
  message           String?
  status            String   @default("pending")
  createdAt         DateTime @default(now())
}
